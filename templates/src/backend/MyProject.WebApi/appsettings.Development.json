{
	"ConnectionStrings": {
		"Database": "Host=localhost;Port=5432;Database={INIT_PROJECT_SLUG};Username=postgres;Password=DevPassword123!"
	},
	"Serilog": {
		"MinimumLevel": {
			"Default": "Debug",
			"Override": {
				"Microsoft.AspNetCore": "Warning",
				"Microsoft.EntityFrameworkCore.Database.Command": "Warning"
			}
		}
	},
	// @feature auth
	"Caching": {
		"Enabled": true,
		"DefaultExpiration": "00:10:00"
	},
	// @end
	"RateLimiting": {
		"Global": {
			"PermitLimit": 300,
			"Window": "00:00:10"
		},
		// @feature auth
		"Registration": {
			"PermitLimit": 50,
			"Window": "00:00:10"
		},
		"Auth": {
			"PermitLimit": 300,
			"Window": "00:00:10"
		},
		"Sensitive": {
			"PermitLimit": 300,
			"Window": "00:00:10"
		},
		// @end
		// @feature admin
		"AdminMutations": {
			"PermitLimit": 300,
			"Window": "00:00:10"
		}
		// @end
	},
	// @feature auth
	"Authentication": {
		"Jwt": {
			"Key": "ThisIsADevelopmentJwtSecretKeyThatIsLongEnoughForHMACSHA256Signing",
			"AccessTokenLifetime": "01:40:00"
		},
		// @feature oauth
		"ExternalProviders": {
			"AllowedRedirectUris": ["http://localhost:{INIT_FRONTEND_PORT}/oauth/callback"],
			"EncryptionKey": "ThisIsADevelopmentOnlyEncryptionKeyThatIsAtLeast32CharsLong!"
		}
		// @end
	},
	// @end
	// @feature auth
	"Email": {
		"Enabled": true,
		"FrontendBaseUrl": "http://localhost:{INIT_FRONTEND_PORT}",
		"Smtp": {
			"Host": "localhost",
			"Port": 1025,
			"UseSsl": false
		}
	},
	// @end
	// @feature captcha
	"Captcha": {
		"SecretKey": "1x0000000000000000000000000000000AA"
	},
	// @end
	// @feature file-storage
	"FileStorage": {
		"Endpoint": "http://localhost:9000",
		"AccessKey": "admin",
		"SecretKey": "DevPassword123!",
		"BucketName": "{INIT_PROJECT_SLUG}-files",
		"UseSSL": false
	},
	// @end
	"Hosting": {
		"ForceHttps": false
	},
	"Cors": {
		"AllowAllOrigins": true
	},
	// @feature auth
	"Seed": {
		"Users": [
			{ "Email": "superuser@test.com", "Password": "Superuser123!", "Role": "Superuser" }
		]
	}
	// @end
}
