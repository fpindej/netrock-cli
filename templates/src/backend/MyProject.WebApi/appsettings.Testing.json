{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    }
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=test_db;Username=test;Password=test"
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 10000,
      "Window": "00:00:10"
    }
  },
  "Hosting": {
    "ForceHttps": false
  },
  "Cors": {
    "AllowAllOrigins": false,
    "AllowedOrigins": [
      "https://test.example.com"
    ],
    "PolicyName": "DefaultCorsPolicy"
  }
}
