{
	"name": "@netrock/core",
	"version": "0.9.1",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:matrix": "vitest run --config vitest.matrix.config.ts",
		"test:watch": "vitest",
		"lint": "tsc --noEmit",
		"check": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"tsup": "^8.0.0",
		"typescript": "^5.9.0",
		"vitest": "^3.2.0"
	}
}
