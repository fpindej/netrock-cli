[
  ".config/dotnet-tools.json",
  ".gitignore",
  "README.md",
  "global.json",
  "setup.ps1",
  "setup.sh",
  "src/backend/.dockerignore",
  "src/backend/.editorconfig",
  "src/backend/Directory.Build.props",
  "src/backend/Directory.Packages.props",
  "src/backend/SnapshotApp.Application/Caching/Constants/CacheKeys.cs",
  "src/backend/SnapshotApp.Application/Cookies/Constants/CookieNames.cs",
