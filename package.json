{
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "check": "pnpm -r run check",
    "format": "prettier --write .",
    "generate": "pnpm --filter @netrock/core build && tsx scripts/generate.ts"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@netrock/core": "workspace:*",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
